# OLLAMA_HOST: Local Ollama server host.
# Default is 127.0.0.1 when running Ollama locally.
OLLAMA_HOST="127.0.0.1"

# OLLAMA_PORT: Local Ollama server port.
# Default is 11434 when using the standard Ollama HTTP service.
OLLAMA_PORT="11434"

# OLLAMA_MODEL: Local Ollama model name to use for text generation.
# Default is llama2.
OLLAMA_MODEL="llama2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
